---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { WHATSAPP_URL } from '../data/services';
import { config } from '../data/clinic-config';
---

<Layout title="Depoimentos de Pacientes" description={`Veja o que nossos pacientes dizem sobre ${config.name}. Histórias reais de transformação e confiança.`}>

  <section class="bg-warm-900 py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Início', href: '/' }, { label: 'Depoimentos' }]} />
      <div class="max-w-3xl animate-on-scroll">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
          Quem passou por aqui,<br /><span class="bg-gradient-to-r from-gold-300 to-gold-500 bg-clip-text text-transparent">recomenda</span>
        </h1>
        <p class="mt-6 text-lg text-white/50 leading-relaxed">A melhor propaganda é um paciente feliz.</p>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 relative">
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 z-10 text-center">
      <div class="luxury-card p-12 animate-on-scroll">
        <div class="w-16 h-16 bg-gold-50 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-warm-900 mb-4">Em breve, depoimentos dos nossos pacientes</h2>
        <p class="text-warm-400 leading-relaxed max-w-lg mx-auto">
          Estamos coletando depoimentos reais com consentimento adequado. Enquanto isso, você pode conferir nossas avaliações no Google Business Profile.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-warm-900">
    <div class="max-w-3xl mx-auto px-4 text-center animate-on-scroll">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Sua história pode ser a próxima</h2>
      <p class="text-white/40 mb-8">Agende uma avaliação e comece sua transformação.</p>
      <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-white text-warm-900 font-bold px-8 py-4 rounded-full hover:bg-gold-50 transition-all btn-press">
        Agendar Consulta
      </a>
    </div>
  </section>
</Layout>
